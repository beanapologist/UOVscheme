# Stripe TEST mode — copy to .env.test for local dev (no real charges)
# Get keys: https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Local API + Next.js
SILENTVERIFY_PUBLIC_URL=http://localhost:3000

# Optional: set when running stripe_bootstrap.sh test with a public tunnel
# WEBHOOK_URL=https://your-tunnel.example.com/api/v1/billing/webhook

# Optional local overrides
# SILENTVERIFY_UOV_PROFILE=TOY
# SILENTVERIFY_DEV_API_KEY=sv_dev_test_key
