{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements-saas.txt"
  },
  "deploy": {
    "startCommand": "python3 -m uvicorn api.app:app --host 0.0.0.0 --port ${PORT:-8080}",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 180,
    "restartPolicyType": "ON_FAILURE"
  }
}
